rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // isAdmin: email-only check — NO database reads, zero latency
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "darshanderkar20@gmail.com" ||
        request.auth.token.email == "derkardarshan@gmail.com"
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['sessions']) ||
          request.resource.data.get('sessions', {}).size() <= 2
        ))
      );
      allow delete: if isAdmin();
    }

    // Sub-collections: own data or admin
    match /users/{userId}/{subcol}/{docId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /requests/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /enquiries/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminLogs/{docId} {
      allow read, write: if isAdmin();
    }

    match /accessRequests/{docId} {
      allow read, delete, update: if isAdmin();
      allow create: if request.auth != null;
    }

    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
